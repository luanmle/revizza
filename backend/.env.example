# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=config.settings.dev
# prod (config.settings.prod) exige também:
DJANGO_ALLOWED_HOSTS=api.example.com
DJANGO_CORS_ALLOWED_ORIGINS=https://app.example.com

# Postgres via Supavisor (Heroku não tem IPv6 de saída; a conexão direta ao banco é IPv6-only).
# Copie a connection string "Session pooler" do dashboard do Supabase (porta 5432;
# a 6543/transaction também funciona — DISABLE_SERVER_SIDE_CURSORS já está ligado em prod).
# Sem DATABASE_URL, dev/testes caem no sqlite local.
DATABASE_URL=postgresql://postgres.PROJECTID:PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# Supabase
SUPABASE_URL=https://PROJECTID.supabase.co
# Secret key do backend (Settings → API keys; formato atual sb_secret_..., o
# service_role legado também funciona). Nunca expor no frontend/add-on.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
# Só para tokens HS256 legados (JWT Secret antigo). Deixe vazio com signing keys
# assimétricas atuais — a verificação usa o JWKS do projeto (T126).
SUPABASE_JWT_SECRET=

# E-mail transacional (prod; dev usa console backend)
DEFAULT_FROM_EMAIL=AnkiHub Brasil <nao-responda@example.com>
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true

# Observabilidade (opcional)
SENTRY_DSN=
